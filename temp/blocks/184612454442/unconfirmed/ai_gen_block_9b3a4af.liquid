{% doc %}
  @prompt
    A magazine-style editorial layout
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-editorial-layout-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px;
  }

  .ai-editorial-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    position: relative;
  }

  .ai-editorial-feature-{{ ai_gen_id }} {
    grid-column: span 7;
    position: relative;
    overflow: hidden;
  }

  .ai-editorial-feature-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    min-height: 500px;
    object-fit: cover;
    display: block;
  }

  .ai-editorial-feature-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    min-height: 500px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-editorial-feature-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-editorial-feature-content-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: {{ block.settings.content_padding }}px;
    background: linear-gradient(to top, rgba(0, 0, 0, {{ block.settings.overlay_opacity }}), transparent);
    color: {{ block.settings.feature_text_color }};
  }

  .ai-editorial-category-{{ ai_gen_id }} {
    font-size: {{ block.settings.category_size }}px;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 12px;
    font-weight: 600;
    color: {{ block.settings.feature_text_color }};
  }

  .ai-editorial-feature-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.feature_title_size }}px;
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    line-height: 1.2;
    margin: 0 0 16px;
    color: {{ block.settings.feature_text_color }};
  }

  .ai-editorial-feature-excerpt-{{ ai_gen_id }} {
    font-size: {{ block.settings.excerpt_size }}px;
    line-height: 1.6;
    margin: 0 0 20px;
    color: {{ block.settings.feature_text_color }};
  }

  .ai-editorial-feature-link-{{ ai_gen_id }} {
    display: inline-block;
    font-size: {{ block.settings.link_size }}px;
    color: {{ block.settings.feature_text_color }};
    text-decoration: none;
    border-bottom: 2px solid {{ block.settings.feature_text_color }};
    padding-bottom: 4px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .ai-editorial-sidebar-{{ ai_gen_id }} {
    grid-column: span 5;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-editorial-card-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    background-color: {{ block.settings.card_background }};
    overflow: hidden;
    position: relative;
  }

  .ai-editorial-card-image-{{ ai_gen_id }} {
    width: 100%;
    height: 240px;
    object-fit: cover;
    display: block;
  }

  .ai-editorial-card-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 240px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-editorial-card-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-editorial-card-content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    flex-grow: 1;
  }

  .ai-editorial-card-category-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_category_size }}px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 8px;
    font-weight: 600;
    color: {{ block.settings.card_text_color }};
    opacity: 0.7;
  }

  .ai-editorial-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    line-height: 1.3;
    margin: 0 0 12px;
    color: {{ block.settings.card_text_color }};
  }

  .ai-editorial-card-excerpt-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_excerpt_size }}px;
    line-height: 1.6;
    margin: 0;
    color: {{ block.settings.card_text_color }};
    opacity: 0.8;
  }

  .ai-editorial-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 989px) {
    .ai-editorial-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-editorial-feature-{{ ai_gen_id }},
    .ai-editorial-sidebar-{{ ai_gen_id }} {
      grid-column: span 1;
    }

    .ai-editorial-feature-image-{{ ai_gen_id }},
    .ai-editorial-feature-placeholder-{{ ai_gen_id }} {
      min-height: 400px;
    }

    .ai-editorial-feature-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.feature_title_size }}px * 0.7);
    }

    .ai-editorial-card-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.card_title_size }}px * 0.85);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-editorial-layout-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | times: 0.5 }}px;
    }

    .ai-editorial-feature-image-{{ ai_gen_id }},
    .ai-editorial-feature-placeholder-{{ ai_gen_id }} {
      min-height: 300px;
    }

    .ai-editorial-card-image-{{ ai_gen_id }},
    .ai-editorial-card-placeholder-{{ ai_gen_id }} {
      height: 200px;
    }
  }
{% endstyle %}

<editorial-layout-{{ ai_gen_id }} class="ai-editorial-layout-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-editorial-grid-{{ ai_gen_id }}">
    <article class="ai-editorial-feature-{{ ai_gen_id }}">
      {% if block.settings.feature_image %}
        <img
          src="{{ block.settings.feature_image | image_url: width: 1400 }}"
          alt="{{ block.settings.feature_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.feature_image.width }}"
          height="{{ block.settings.feature_image.height }}"
          class="ai-editorial-feature-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-editorial-feature-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
          <div class="ai-editorial-empty-state-{{ ai_gen_id }}">
            Add a featured image
          </div>
        </div>
      {% endif %}

      <div class="ai-editorial-feature-content-{{ ai_gen_id }}">
        {% if block.settings.feature_category != blank %}
          <div class="ai-editorial-category-{{ ai_gen_id }}">{{ block.settings.feature_category }}</div>
        {% endif %}

        {% if block.settings.feature_title != blank %}
          <h2 class="ai-editorial-feature-title-{{ ai_gen_id }}">{{ block.settings.feature_title }}</h2>
        {% endif %}

        {% if block.settings.feature_excerpt != blank %}
          <div class="ai-editorial-feature-excerpt-{{ ai_gen_id }}">{{ block.settings.feature_excerpt }}</div>
        {% endif %}

        {% if block.settings.feature_link != blank %}
          <a href="{{ block.settings.feature_link }}" class="ai-editorial-feature-link-{{ ai_gen_id }}">
            {{ block.settings.feature_link_text }}
          </a>
        {% endif %}
      </div>
    </article>

    <aside class="ai-editorial-sidebar-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign card_image_key = 'card_' | append: i | append: '_image'
          assign card_category_key = 'card_' | append: i | append: '_category'
          assign card_title_key = 'card_' | append: i | append: '_title'
          assign card_excerpt_key = 'card_' | append: i | append: '_excerpt'
          assign card_link_key = 'card_' | append: i | append: '_link'

          assign card_image = block.settings[card_image_key]
          assign card_category = block.settings[card_category_key]
          assign card_title = block.settings[card_title_key]
          assign card_excerpt = block.settings[card_excerpt_key]
          assign card_link = block.settings[card_link_key]
        %}

        <article class="ai-editorial-card-{{ ai_gen_id }}">
          {% if card_link != blank %}
            <a href="{{ card_link }}" style="display: block;">
          {% endif %}

          {% if card_image %}
            <img
              src="{{ card_image | image_url: width: 800 }}"
              alt="{{ card_image.alt | escape }}"
              loading="lazy"
              width="{{ card_image.width }}"
              height="{{ card_image.height }}"
              class="ai-editorial-card-image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-editorial-card-placeholder-{{ ai_gen_id }}">
              {{ 'product-apparel-1' | placeholder_svg_tag }}
            </div>
          {% endif %}

          {% if card_link != blank %}
            </a>
          {% endif %}

          <div class="ai-editorial-card-content-{{ ai_gen_id }}">
            {% if card_category != blank %}
              <div class="ai-editorial-card-category-{{ ai_gen_id }}">{{ card_category }}</div>
            {% endif %}

            {% if card_title != blank %}
              {% if card_link != blank %}
                <a href="{{ card_link }}" style="text-decoration: none; color: inherit;">
                  <h3 class="ai-editorial-card-title-{{ ai_gen_id }}">{{ card_title }}</h3>
                </a>
              {% else %}
                <h3 class="ai-editorial-card-title-{{ ai_gen_id }}">{{ card_title }}</h3>
              {% endif %}
            {% endif %}

            {% if card_excerpt != blank %}
              <p class="ai-editorial-card-excerpt-{{ ai_gen_id }}">{{ card_excerpt }}</p>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </aside>
  </div>
</editorial-layout-{{ ai_gen_id }}>

<script>
  (function() {
    class EditorialLayout{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAccessibility();
      }

      setupAccessibility() {
        const articles = this.querySelectorAll('article');
        articles.forEach((article) => {
          article.setAttribute('role', 'article');
        });
      }
    }

    customElements.define('editorial-layout-{{ ai_gen_id }}', EditorialLayout{{ ai_gen_id }});
  })();
</script>

