{% doc %}
  @prompt
    A magazine-style editorial layout
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-magazine-layout-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px;
  }

  .ai-magazine-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    width: 100%;
  }

  .ai-magazine-feature-{{ ai_gen_id }} {
    grid-column: span 8;
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-magazine-feature-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    min-height: 500px;
    object-fit: cover;
    display: block;
  }

  .ai-magazine-feature-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    min-height: 500px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-magazine-feature-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-magazine-feature-overlay-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: {{ block.settings.overlay_padding }}px;
    background: linear-gradient(to top, {{ block.settings.overlay_color }}, transparent);
    color: {{ block.settings.overlay_text_color }};
  }

  .ai-magazine-feature-category-{{ ai_gen_id }} {
    font-size: {{ block.settings.category_font_size }}px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 8px;
    font-weight: 600;
    opacity: 0.9;
  }

  .ai-magazine-feature-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.feature_title_size }}px;
    line-height: 1.2;
    margin: 0 0 12px;
    font-weight: 700;
  }

  .ai-magazine-feature-excerpt-{{ ai_gen_id }} {
    font-size: {{ block.settings.excerpt_font_size }}px;
    line-height: 1.6;
    margin: 0 0 16px;
    opacity: 0.95;
  }

  .ai-magazine-feature-link-{{ ai_gen_id }} {
    display: inline-block;
    color: {{ block.settings.overlay_text_color }};
    text-decoration: none;
    font-size: {{ block.settings.link_font_size }}px;
    font-weight: 600;
    border-bottom: 2px solid {{ block.settings.overlay_text_color }};
    padding-bottom: 2px;
  }

  .ai-magazine-sidebar-{{ ai_gen_id }} {
    grid-column: span 4;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-magazine-card-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-magazine-card-image-{{ ai_gen_id }} {
    width: 100%;
    height: 240px;
    object-fit: cover;
    display: block;
  }

  .ai-magazine-card-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 240px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-magazine-card-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-magazine-card-overlay-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: {{ block.settings.card_overlay_padding }}px;
    background: linear-gradient(to top, {{ block.settings.overlay_color }}, transparent);
    color: {{ block.settings.overlay_text_color }};
  }

  .ai-magazine-card-category-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_category_size }}px;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 4px;
    font-weight: 600;
    opacity: 0.9;
  }

  .ai-magazine-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    line-height: 1.3;
    margin: 0;
    font-weight: 700;
  }

  .ai-magazine-bottom-row-{{ ai_gen_id }} {
    grid-column: span 12;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-top: {{ block.settings.grid_gap }}px;
  }

  .ai-magazine-small-card-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-magazine-small-card-image-{{ ai_gen_id }} {
    width: 100%;
    height: 280px;
    object-fit: cover;
    display: block;
  }

  .ai-magazine-small-card-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 280px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-magazine-small-card-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-magazine-small-card-overlay-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: {{ block.settings.card_overlay_padding }}px;
    background: linear-gradient(to top, {{ block.settings.overlay_color }}, transparent);
    color: {{ block.settings.overlay_text_color }};
  }

  .ai-magazine-small-card-category-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_category_size }}px;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 4px;
    font-weight: 600;
    opacity: 0.9;
  }

  .ai-magazine-small-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    line-height: 1.3;
    margin: 0;
    font-weight: 700;
  }

  @media screen and (max-width: 989px) {
    .ai-magazine-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-magazine-feature-{{ ai_gen_id }},
    .ai-magazine-sidebar-{{ ai_gen_id }} {
      grid-column: span 1;
    }

    .ai-magazine-bottom-row-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-magazine-layout-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | times: 0.5 }}px;
    }

    .ai-magazine-feature-image-{{ ai_gen_id }},
    .ai-magazine-feature-placeholder-{{ ai_gen_id }} {
      min-height: 350px;
    }

    .ai-magazine-feature-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.feature_title_size | times: 0.7 }}px;
    }

    .ai-magazine-card-title-{{ ai_gen_id }},
    .ai-magazine-small-card-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.card_title_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<magazine-editorial-{{ ai_gen_id }} class="ai-magazine-layout-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-magazine-grid-{{ ai_gen_id }}">
    <div class="ai-magazine-feature-{{ ai_gen_id }}">
      {% if block.settings.feature_image %}
        <img
          src="{{ block.settings.feature_image | image_url: width: 1200 }}"
          alt="{{ block.settings.feature_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.feature_image.width }}"
          height="{{ block.settings.feature_image.height }}"
          class="ai-magazine-feature-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-magazine-feature-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
      <div class="ai-magazine-feature-overlay-{{ ai_gen_id }}">
        {% if block.settings.feature_category != blank %}
          <div class="ai-magazine-feature-category-{{ ai_gen_id }}">{{ block.settings.feature_category }}</div>
        {% endif %}
        {% if block.settings.feature_title != blank %}
          <h2 class="ai-magazine-feature-title-{{ ai_gen_id }}">{{ block.settings.feature_title }}</h2>
        {% endif %}
        {% if block.settings.feature_excerpt != blank %}
          <div class="ai-magazine-feature-excerpt-{{ ai_gen_id }}">{{ block.settings.feature_excerpt }}</div>
        {% endif %}
        {% if block.settings.feature_link != blank %}
          <a href="{{ block.settings.feature_link }}" class="ai-magazine-feature-link-{{ ai_gen_id }}">
            {{ block.settings.feature_link_text }}
          </a>
        {% endif %}
      </div>
    </div>

    <div class="ai-magazine-sidebar-{{ ai_gen_id }}">
      <div class="ai-magazine-card-{{ ai_gen_id }}">
        {% if block.settings.card_1_image %}
          <img
            src="{{ block.settings.card_1_image | image_url: width: 600 }}"
            alt="{{ block.settings.card_1_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.card_1_image.width }}"
            height="{{ block.settings.card_1_image.height }}"
            class="ai-magazine-card-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-magazine-card-placeholder-{{ ai_gen_id }}">
            {{ 'collection-apparel-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
        <div class="ai-magazine-card-overlay-{{ ai_gen_id }}">
          {% if block.settings.card_1_category != blank %}
            <div class="ai-magazine-card-category-{{ ai_gen_id }}">{{ block.settings.card_1_category }}</div>
          {% endif %}
          {% if block.settings.card_1_title != blank %}
            <h3 class="ai-magazine-card-title-{{ ai_gen_id }}">{{ block.settings.card_1_title }}</h3>
          {% endif %}
        </div>
      </div>

      <div class="ai-magazine-card-{{ ai_gen_id }}">
        {% if block.settings.card_2_image %}
          <img
            src="{{ block.settings.card_2_image | image_url: width: 600 }}"
            alt="{{ block.settings.card_2_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.card_2_image.width }}"
            height="{{ block.settings.card_2_image.height }}"
            class="ai-magazine-card-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-magazine-card-placeholder-{{ ai_gen_id }}">
            {{ 'product-apparel-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
        <div class="ai-magazine-card-overlay-{{ ai_gen_id }}">
          {% if block.settings.card_2_category != blank %}
            <div class="ai-magazine-card-category-{{ ai_gen_id }}">{{ block.settings.card_2_category }}</div>
          {% endif %}
          {% if block.settings.card_2_title != blank %}
            <h3 class="ai-magazine-card-title-{{ ai_gen_id }}">{{ block.settings.card_2_title }}</h3>
          {% endif %}
        </div>
      </div>
    </div>

    <div class="ai-magazine-bottom-row-{{ ai_gen_id }}">
      <div class="ai-magazine-small-card-{{ ai_gen_id }}">
        {% if block.settings.card_3_image %}
          <img
            src="{{ block.settings.card_3_image | image_url: width: 500 }}"
            alt="{{ block.settings.card_3_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.card_3_image.width }}"
            height="{{ block.settings.card_3_image.height }}"
            class="ai-magazine-small-card-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-magazine-small-card-placeholder-{{ ai_gen_id }}">
            {{ 'detailed-apparel-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
        <div class="ai-magazine-small-card-overlay-{{ ai_gen_id }}">
          {% if block.settings.card_3_category != blank %}
            <div class="ai-magazine-small-card-category-{{ ai_gen_id }}">{{ block.settings.card_3_category }}</div>
          {% endif %}
          {% if block.settings.card_3_title != blank %}
            <h3 class="ai-magazine-small-card-title-{{ ai_gen_id }}">{{ block.settings.card_3_title }}</h3>
          {% endif %}
        </div>
      </div>

      <div class="ai-magazine-small-card-{{ ai_gen_id }}">
        {% if block.settings.card_4_image %}
          <img
            src="{{ block.settings.card_4_image | image_url: width: 500 }}"
            alt="{{ block.settings.card_4_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.card_4_image.width }}"
            height="{{ block.settings.card_4_image.height }}"
            class="ai-magazine-small-card-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-magazine-small-card-placeholder-{{ ai_gen_id }}">
            {{ 'blog-apparel-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
        <div class="ai-magazine-small-card-overlay-{{ ai_gen_id }}">
          {% if block.settings.card_4_category != blank %}
            <div class="ai-magazine-small-card-category-{{ ai_gen_id }}">{{ block.settings.card_4_category }}</div>
          {% endif %}
          {% if block.settings.card_4_title != blank %}
            <h3 class="ai-magazine-small-card-title-{{ ai_gen_id }}">{{ block.settings.card_4_title }}</h3>
          {% endif %}
        </div>
      </div>

      <div class="ai-magazine-small-card-{{ ai_gen_id }}">
        {% if block.settings.card_5_image %}
          <img
            src="{{ block.settings.card_5_image | image_url: width: 500 }}"
            alt="{{ block.settings.card_5_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.card_5_image.width }}"
            height="{{ block.settings.card_5_image.height }}"
            class="ai-magazine-small-card-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-magazine-small-card-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
        <div class="ai-magazine-small-card-overlay-{{ ai_gen_id }}">
          {% if block.settings.card_5_category != blank %}
            <div class="ai-magazine-small-card-category-{{ ai_gen_id }}">{{ block.settings.card_5_category }}</div>
          {% endif %}
          {% if block.settings.card_5_title != blank %}
            <h3 class="ai-magazine-small-card-title-{{ ai_gen_id }}">{{ block.settings.card_5_title }}</h3>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</magazine-editorial-{{ ai_gen_id }}>

<script>
  (function() {
    class MagazineEditorial{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupClickHandlers();
      }

      setupClickHandlers() {
        const cards = this.querySelectorAll('[class*="ai-magazine-card-"], [class*="ai-magazine-small-card-"], [class*="ai-magazine-feature-"]');
        
        cards.forEach((card) => {
          const link = card.querySelector('a');
          if (link) {
            card.style.cursor = 'pointer';
            card.addEventListener('click', (e) => {
              if (e.target.tagName !== 'A') {
                link.click();
              }
            });
          }
        });
      }
    }

    customElements.define('magazine-editorial-{{ ai_gen_id }}', MagazineEditorial{{ ai_gen_id }});
  })();
</script>

